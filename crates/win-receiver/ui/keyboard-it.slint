import { LineEdit, Button, CheckBox, VerticalBox, HorizontalBox, GroupBox, AboutSlint } from "std-widgets.slint";

// Small settings window — opened from the tray via "Settings...", the app outlives closing it.
export component SettingsWindow inherits Window {
    title: "keyboard-it";
    preferred-width: 380px;
    preferred-height: 400px;

    in property <bool> active;                 // listener state (ACTIVE/INACTIVE)
    in property <string> this-pc;              // "This PC: HOSTNAME — 192.168.1.x" (from Rust)
    in-out property <string> pairing-key;
    in-out property <string> peer-ip;
    in-out property <string> peer-port;
    in-out property <bool> autostart;
    in property <string> status-line;          // info/error message from Rust

    callback start-listener();
    callback stop-listener();
    callback save();
    callback autostart-changed(bool);
    callback generate-key();

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        Text {
            text: root.active ? "● ACTIVE — listening on 5599" : "○ INACTIVE — stopped";
            color: root.active ? #2e7d32 : #b71c1c;
            font-size: 15px;
            font-weight: 700;
        }

        // Identity line: what the user reads aloud if automatic discovery fails.
        Text { text: root.this-pc; font-size: 12px; }

        GroupBox {
            title: "Settings";
            VerticalBox {
                spacing: 6px;
                Text { text: "Pairing key (must be IDENTICAL on both machines)"; }
                HorizontalBox {
                    padding: 0px;
                    spacing: 6px;
                    LineEdit {
                        placeholder-text: "KEYBOARD_IT_KEY";
                        text <=> root.pairing-key;
                        horizontal-stretch: 1;
                    }
                    Button { text: "Generate"; clicked => { root.generate-key(); } }
                }
                Text { text: "Use the same key on the Mac."; font-size: 11px; color: #808080; }
                Text { text: "Peer IP (the sending Mac)"; }
                LineEdit { placeholder-text: "192.168.1.x"; text <=> root.peer-ip; }
                Text { text: "Port"; }
                LineEdit { placeholder-text: "5599"; text <=> root.peer-port; }
                CheckBox {
                    text: "Start automatically at logon (elevated)";
                    checked <=> root.autostart;
                    toggled => { root.autostart-changed(self.checked); }
                }
            }
        }

        HorizontalBox {
            spacing: 8px;
            Button {
                text: root.active ? "Stop" : "Start";
                clicked => {
                    if (root.active) { root.stop-listener(); } else { root.start-listener(); }
                }
            }
            Button { text: "Save"; clicked => { root.save(); } }
        }

        Text { text: root.status-line; color: #808080; font-size: 12px; }

        Rectangle { vertical-stretch: 1; }
        AboutSlint { }
    }
}

// System tray icon (Slint 1.17 native SystemTrayIcon → Shell_NotifyIconW).
// Parity with the Mac menu bar: state visible at a glance — the icon, tooltip and the
// "Status:" menu line change live with the connection state (Menu is reactive).
export component Tray inherits SystemTrayIcon {
    in property <bool> active;
    // Connection state (from Rust serve::ConnStatus): 0 waiting, 1 connected, 2 key mismatch.
    in property <int> conn: 0;

    // Status text from a single source: the tooltip and the menu line use the same wording.
    property <string> status-text: !root.active ? "Stopped"
        : root.conn == 1 ? "Connected"
        : root.conn == 2 ? "Key mismatch"
        : "Waiting for connection";

    // tray-on/err/off.png = tray.png + green/red dot / grayscale.
    icon: !root.active ? @image-url("tray-off.png")
        : root.conn == 1 ? @image-url("tray-on.png")
        : root.conn == 2 ? @image-url("tray-err.png")
        : @image-url("tray.png");
    tooltip: root.active ? "keyboard-it — ACTIVE — " + root.status-text : "keyboard-it — INACTIVE";

    callback show-settings();
    callback toggle-listener();
    callback quit();

    Menu {
        MenuItem {
            title: "Status: " + root.status-text;
            enabled: false; // non-clickable info line
        }
        MenuSeparator { }
        MenuItem {
            title: root.active ? "Stop" : "Start";
            activated => { root.toggle-listener(); }
        }
        MenuItem {
            title: "Settings...";
            activated => { root.show-settings(); }
        }
        MenuSeparator { }
        MenuItem {
            title: "Quit";
            activated => { root.quit(); }
        }
    }
}
