__pycache__/

# kalfa plugin state files (not part of this project)
.kalfa/
**/.kalfa/

# Cargo.lock: committed on purpose (these are binary crates), so not ignored here.

# wrangler local cache (deploy tool; kept out of the repo)
.wrangler/
